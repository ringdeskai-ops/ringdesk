# RingDesk — Environment Variables

# ── Core ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
JWT_SECRET=change-this-to-a-long-random-string-in-production

# ── Twilio (your master account) ───────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Note: each CLIENT gets their own Twilio number, stored in DB

# ── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Create these in Stripe Dashboard → Products
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxx        # £49/mo
STRIPE_PRICE_PROFESSIONAL=price_xxxxxxxxxxxxxxxxxxxx   # £149/mo
STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxxxxxxxxx       # £349/mo

# ── URLs ───────────────────────────────────────────────
DASHBOARD_URL=https://app.ringdesk.io
SERVER_URL=https://api.ringdesk.io

# ── Server ─────────────────────────────────────────────
PORT=3000
NODE_ENV=production
