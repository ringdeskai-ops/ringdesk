<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>RingDesk — AI Receptionist for Your Business</title>
<meta name="description" content="Never miss a customer call again. RingDesk answers every call 24/7, takes messages, and transfers to your team. From £49/month."/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060912;--surface:#0d1117;--border:#1a2332;
  --text:#f0f4f8;--muted:#8896a8;--dim:#3d4f63;
  --blue:#3b82f6;--blue-light:#60a5fa;--green:#10b981;
  --grad:linear-gradient(135deg,#3b82f6 0%,#8b5cf6 100%);
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',system-ui,sans-serif;line-height:1.6;overflow-x:hidden}
h1,h2,h3,.brand{font-family:'Sora',sans-serif}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:0 max(5vw,24px);height:64px;display:flex;align-items:center;justify-content:space-between;background:rgba(6,9,18,0.85);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,0.04)}
.brand{font-size:22px;font-weight:800;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-1px}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{color:var(--muted);font-size:14px;text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--text)}
.btn{display:inline-flex;align-items:center;gap:8px;padding:10px 22px;border-radius:50px;font-size:14px;font-weight:600;text-decoration:none;cursor:pointer;border:none;transition:all .2s;font-family:inherit}
.btn-primary{background:var(--grad);color:#fff;box-shadow:0 0 30px rgba(59,130,246,.3)}
.btn-primary:hover{transform:translateY(-1px);box-shadow:0 4px 40px rgba(59,130,246,.45)}
.btn-outline{background:transparent;color:var(--text);border:1px solid var(--border)}
.btn-outline:hover{border-color:var(--blue-light);color:var(--blue-light)}

/* ── HERO ── */
#hero{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:100px max(5vw,24px) 80px;position:relative;overflow:hidden}
.hero-glow{position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(59,130,246,.12) 0%,transparent 65%);top:50%;left:50%;transform:translate(-50%,-60%);pointer-events:none}
.hero-grid{position:absolute;inset:0;opacity:.03;background-image:linear-gradient(rgba(99,179,237,.6) 1px,transparent 1px),linear-gradient(90deg,rgba(99,179,237,.6) 1px,transparent 1px);background-size:48px 48px;pointer-events:none}
.badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;border-radius:50px;background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.25);font-size:12px;color:var(--blue-light);letter-spacing:.5px;margin-bottom:28px;font-family:'Sora',sans-serif;font-weight:600}
.badge-dot{width:6px;height:6px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:blink 2s infinite}
h1{font-size:clamp(38px,7vw,76px);font-weight:800;letter-spacing:-3px;line-height:1.06;margin-bottom:24px;max-width:880px}
h1 span{background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.hero-sub{font-size:clamp(16px,2vw,20px);color:var(--muted);max-width:560px;margin:0 auto 40px;font-weight:400}
.hero-ctas{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-bottom:60px}
.hero-proof{display:flex;align-items:center;gap:20px;flex-wrap:wrap;justify-content:center}
.proof-item{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted)}
.proof-item svg{width:16px;height:16px;fill:var(--green)}
.proof-divider{width:1px;height:16px;background:var(--border)}

/* ── PHONE MOCKUP ── */
.mockup-wrap{position:relative;margin:20px auto 0;max-width:340px}
.phone{background:var(--surface);border:1px solid var(--border);border-radius:28px;padding:24px 20px;box-shadow:0 40px 100px rgba(0,0,0,.6),0 0 60px rgba(59,130,246,.08);position:relative;overflow:hidden}
.phone::before{content:'';position:absolute;top:0;left:50%;transform:translateX(-50%);width:80px;height:4px;background:var(--border);border-radius:0 0 4px 4px}
.call-bubble{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.2);border-radius:16px 16px 4px 16px;padding:12px 14px;font-size:13px;color:var(--muted);margin-bottom:10px;line-height:1.5}
.call-bubble.ai{background:rgba(139,92,246,.1);border-color:rgba(139,92,246,.2);border-radius:16px 16px 16px 4px}
.call-bubble .label{font-size:10px;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px;font-family:'Sora',sans-serif;font-weight:600}
.call-bubble.user .label{color:var(--blue-light)}
.call-bubble.ai .label{color:#a78bfa}
.call-status{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--muted);margin-top:14px;padding-top:14px;border-top:1px solid var(--border)}
.call-dot{width:8px;height:8px;border-radius:50%;background:var(--green);box-shadow:0 0 8px var(--green);animation:blink 1.5s infinite}

/* ── LOGOS ── */
#logos{padding:20px max(5vw,24px);text-align:center;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
#logos p{font-size:12px;color:var(--dim);letter-spacing:2px;text-transform:uppercase;margin-bottom:24px;font-family:'Sora',sans-serif}
.logo-row{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:40px}
.logo-item{font-size:14px;font-weight:700;color:var(--dim);font-family:'Sora',sans-serif;letter-spacing:-0.5px;opacity:.6}

/* ── SECTIONS ── */
section{padding:100px max(5vw,24px)}
.section-label{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--blue-light);margin-bottom:16px;font-family:'Sora',sans-serif;font-weight:600}
h2{font-size:clamp(28px,4vw,48px);font-weight:800;letter-spacing:-2px;margin-bottom:16px;line-height:1.1}
.section-sub{font-size:17px;color:var(--muted);max-width:520px;margin-bottom:56px}

/* ── HOW IT WORKS ── */
#how{text-align:center}
.steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:2px;margin-top:56px;border:1px solid var(--border);border-radius:16px;overflow:hidden}
.step{padding:32px 28px;background:var(--surface);text-align:left;position:relative}
.step::after{content:attr(data-num);position:absolute;top:20px;right:20px;font-size:42px;font-weight:800;color:rgba(255,255,255,.03);font-family:'Sora',sans-serif}
.step-icon{font-size:28px;margin-bottom:16px}
.step h3{font-size:17px;font-weight:700;margin-bottom:8px;letter-spacing:-.5px}
.step p{font-size:13px;color:var(--muted);line-height:1.7}

/* ── FEATURES ── */
#features{background:var(--surface)}
.features-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.feat{padding:28px;border-radius:14px;border:1px solid var(--border);background:rgba(255,255,255,.02);transition:border-color .2s}
.feat:hover{border-color:rgba(59,130,246,.3)}
.feat-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:16px}
.feat h3{font-size:16px;font-weight:700;margin-bottom:8px;letter-spacing:-.3px}
.feat p{font-size:13px;color:var(--muted);line-height:1.7}

/* ── PRICING ── */
#pricing{text-align:center}
.plans{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px;max-width:920px;margin:0 auto}
.plan{padding:32px 28px;border-radius:16px;border:1px solid var(--border);background:var(--surface);text-align:left;position:relative;transition:transform .2s}
.plan:hover{transform:translateY(-4px)}
.plan.popular{border-color:rgba(59,130,246,.5);background:rgba(59,130,246,.04)}
.plan-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--grad);color:#fff;font-size:10px;font-weight:700;padding:4px 14px;border-radius:20px;letter-spacing:1px;white-space:nowrap}
.plan-name{font-size:14px;font-weight:700;color:var(--muted);margin-bottom:12px;letter-spacing:1px;text-transform:uppercase;font-family:'Sora',sans-serif}
.plan-price{font-size:44px;font-weight:800;letter-spacing:-2px;margin-bottom:4px;font-family:'Sora',sans-serif}
.plan-price span{font-size:16px;font-weight:400;color:var(--muted);letter-spacing:0}
.plan-calls{font-size:13px;color:var(--green);font-weight:600;margin-bottom:24px}
.plan-features{margin-bottom:28px}
.plan-feature{font-size:13px;color:var(--muted);padding:5px 0;display:flex;align-items:center;gap:8px}
.plan-feature::before{content:'✓';color:var(--green);font-weight:700;flex-shrink:0}
.plan-cta{display:block;text-align:center;padding:12px;border-radius:10px;font-size:14px;font-weight:600;text-decoration:none;transition:all .2s;font-family:inherit;border:none;cursor:pointer;width:100%;font-family:'DM Sans',sans-serif}
.plan-cta-primary{background:var(--grad);color:#fff}
.plan-cta-outline{background:rgba(255,255,255,.06);color:var(--text);border:1px solid var(--border)}
.plan-cta-outline:hover{border-color:var(--blue);color:var(--blue-light)}

/* ── INDUSTRIES ── */
#industries{background:var(--surface)}
.industries-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px}
.industry{padding:20px;border-radius:12px;border:1px solid var(--border);display:flex;align-items:center;gap:12px;transition:all .2s;cursor:default}
.industry:hover{border-color:rgba(59,130,246,.3);background:rgba(59,130,246,.04)}
.industry-icon{font-size:24px;flex-shrink:0}
.industry-name{font-size:13px;font-weight:600;color:var(--text)}
.industry-desc{font-size:11px;color:var(--muted)}

/* ── STATS ── */
#stats{text-align:center}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:0;border:1px solid var(--border);border-radius:16px;overflow:hidden}
.stat{padding:40px 20px;background:var(--surface);border-right:1px solid var(--border)}
.stat:last-child{border-right:none}
.stat-num{font-size:48px;font-weight:800;letter-spacing:-3px;margin-bottom:6px;font-family:'Sora',sans-serif;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.stat-label{font-size:13px;color:var(--muted)}

/* ── TESTIMONIALS ── */
#testimonials{background:var(--surface)}
.testimonials{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px}
.testimonial{padding:28px;border-radius:14px;border:1px solid var(--border);background:rgba(255,255,255,.02)}
.stars{color:#f59e0b;font-size:14px;margin-bottom:14px}
.testimonial blockquote{font-size:14px;color:var(--muted);line-height:1.8;margin-bottom:18px;font-style:italic}
.testimonial-author{display:flex;align-items:center;gap:12px}
.avatar{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.author-name{font-size:13px;font-weight:600;color:var(--text)}
.author-biz{font-size:11px;color:var(--muted)}

/* ── FAQ ── */
#faq{max-width:720px;margin:0 auto}
.faq-item{border-bottom:1px solid var(--border);padding:20px 0}
.faq-q{font-size:15px;font-weight:600;color:var(--text);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px}
.faq-q:hover{color:var(--blue-light)}
.faq-a{font-size:14px;color:var(--muted);line-height:1.8;max-height:0;overflow:hidden;transition:max-height .3s,padding .3s}
.faq-item.open .faq-a{max-height:200px;padding-top:12px}
.faq-arrow{transition:transform .3s;color:var(--dim)}
.faq-item.open .faq-arrow{transform:rotate(180deg)}

/* ── CTA FOOTER ── */
#cta-footer{text-align:center;padding:100px max(5vw,24px);position:relative;overflow:hidden}
#cta-footer::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at center,rgba(59,130,246,.08) 0%,transparent 70%);pointer-events:none}
#cta-footer h2{font-size:clamp(28px,5vw,56px);font-weight:800;letter-spacing:-2px;margin-bottom:16px}
#cta-footer p{font-size:17px;color:var(--muted);margin-bottom:36px}

/* ── FOOTER ── */
footer{padding:40px max(5vw,24px);border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px}
footer .brand{font-size:18px}
.footer-links{display:flex;gap:24px;flex-wrap:wrap}
.footer-links a{font-size:13px;color:var(--muted);text-decoration:none}
.footer-links a:hover{color:var(--text)}
.footer-copy{font-size:12px;color:var(--dim)}

/* ── ANIMATIONS ── */
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.float{animation:float 4s ease-in-out infinite}

/* ── RESPONSIVE ── */
@media(max-width:640px){
  .nav-links a:not(:last-child){display:none}
  .hero-ctas{flex-direction:column;align-items:center}
  .stat{border-right:none;border-bottom:1px solid var(--border)}
  footer{flex-direction:column;text-align:center}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="brand">RingDesk</div>
  <div class="nav-links">
    <a href="#how">How it works</a>
    <a href="#pricing">Pricing</a>
    <a href="#faq">FAQ</a>
    <a href="tel:+442046348499" style="color:var(--muted);font-size:13px;text-decoration:none;display:flex;align-items:center;gap:6px">📞 +44 20 4634 8499</a>
    <a href="/dashboard" class="btn btn-outline" style="padding:8px 18px;font-size:13px">Sign in</a>
    <a href="/dashboard" class="btn btn-primary" style="padding:8px 18px;font-size:13px">Start free trial</a>
  </div>
</nav>

<!-- HERO -->
<section id="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="badge"><span class="badge-dot"></span> AI-powered · Live 24/7 · No hold music</div>
  <h1>Your business <span>never misses</span><br>a call again</h1>
  <p class="hero-sub">RingDesk answers every customer call instantly — day or night. Your AI receptionist books appointments, takes messages, and transfers to your team when needed.</p>
  <div class="hero-ctas">
    <a href="/dashboard" class="btn btn-primary" style="padding:14px 32px;font-size:16px">Start free trial — no card needed</a>
    <a href="tel:+442046348499" class="btn btn-outline" style="padding:14px 28px;font-size:16px">📞 +44 20 4634 8499</a>
  </div>
  <div class="hero-proof">
    <div class="proof-item"><svg viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>Setup in 30 minutes</div>
    <div class="proof-divider"></div>
    <div class="proof-item"><svg viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>Cancel anytime</div>
    <div class="proof-divider"></div>
    <div class="proof-item"><svg viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"/></svg>From £49/month</div>
  </div>

  <!-- Phone mockup -->
  <div class="mockup-wrap float" style="margin-top:60px">
    <div class="phone">
      <div class="call-bubble user">
        <div class="label">Caller</div>
        Hi, I'd like to book an appointment for next Tuesday?
      </div>
      <div class="call-bubble ai">
        <div class="label">Aria · AI Receptionist</div>
        Of course! I'd be happy to help. Could I take your name and what the appointment is for?
      </div>
      <div class="call-bubble user">
        <div class="label">Caller</div>
        It's Sarah, for a consultation.
      </div>
      <div class="call-bubble ai">
        <div class="label">Aria · AI Receptionist</div>
        Perfect, Sarah. I've logged that for Tuesday. You'll get a confirmation shortly. Is there anything else I can help with?
      </div>
      <div class="call-status"><div class="call-dot"></div>Live call · 1m 24s · AI handling</div>
    </div>
  </div>
</section>

<!-- LOGOS -->
<div id="logos">
  <p>Trusted by businesses across the UK</p>
  <div class="logo-row">
    <div class="logo-item">Westside Dental</div>
    <div class="logo-item">Alpine Estates</div>
    <div class="logo-item">FastFix Plumbing</div>
    <div class="logo-item">Glow Beauty Studio</div>
    <div class="logo-item">Peak Fitness</div>
    <div class="logo-item">Meridian Law</div>
  </div>
</div>

<!-- STATS -->
<section id="stats">
  <div class="section-label">By the numbers</div>
  <h2>Why businesses choose RingDesk</h2>
  <div class="stats-grid" style="margin-top:48px">
    <div class="stat"><div class="stat-num">62%</div><div class="stat-label">of callers hang up without leaving a voicemail</div></div>
    <div class="stat"><div class="stat-num">£25k</div><div class="stat-label">average cost of a full-time receptionist per year</div></div>
    <div class="stat"><div class="stat-num">24/7</div><div class="stat-label">AI availability vs 9–5 human coverage</div></div>
    <div class="stat"><div class="stat-num">83%</div><div class="stat-label">gross margin per customer at Starter plan</div></div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="how">
  <div style="text-align:center">
    <div class="section-label">How it works</div>
    <h2>Up and running in 30 minutes</h2>
    <p class="section-sub" style="margin:0 auto 0">No technical knowledge needed. We handle the hard part.</p>
  </div>
  <div class="steps">
    <div class="step" data-num="1">
      <div class="step-icon">📞</div>
      <h3>Get a real phone number</h3>
      <p>We connect a UK or international number to your account. Display it on your website, cards, and listings.</p>
    </div>
    <div class="step" data-num="2">
      <div class="step-icon">🤖</div>
      <h3>Tell Aria about your business</h3>
      <p>Paste in your hours, FAQs, and pricing. Aria learns your business and answers calls exactly as you'd want.</p>
    </div>
    <div class="step" data-num="3">
      <div class="step-icon">📲</div>
      <h3>Customers call your number</h3>
      <p>Aria answers instantly, handles enquiries, books appointments, and takes messages — 24 hours a day.</p>
    </div>
    <div class="step" data-num="4">
      <div class="step-icon">👤</div>
      <h3>Complex calls transfer to you</h3>
      <p>When a caller needs a human, Aria transfers them to the right team with a summary already prepared.</p>
    </div>
  </div>
</section>

<!-- FEATURES -->
<section id="features">
  <div class="section-label">Features</div>
  <h2>Everything your receptionist<br>should do — automated</h2>
  <p class="section-sub">Built for real businesses. No gimmicks.</p>
  <div class="features-grid">
    <div class="feat"><div class="feat-icon" style="background:rgba(59,130,246,.12)">🎙️</div><h3>Natural AI conversation</h3><p>Powered by Claude AI. Understands context, handles interruptions, and sounds completely natural on the phone.</p></div>
    <div class="feat"><div class="feat-icon" style="background:rgba(16,185,129,.12)">↗</div><h3>Smart call transfers</h3><p>Aria detects when to escalate and transfers to the right department with a handoff summary — no repeating needed.</p></div>
    <div class="feat"><div class="feat-icon" style="background:rgba(245,158,11,.12)">📬</div><h3>Voicemail with AI transcripts</h3><p>When your team is unavailable, Aria takes a voicemail and sends you the transcript by email instantly.</p></div>
    <div class="feat"><div class="feat-icon" style="background:rgba(139,92,246,.12)">📊</div><h3>Full call dashboard</h3><p>Every call logged. Full transcripts. AI summaries. Duration, caller info, outcome — all in one place.</p></div>
    <div class="feat"><div class="feat-icon" style="background:rgba(236,72,153,.12)">⚙</div><h3>Customisable personality</h3><p>Name your AI, write their script, set your business hours and FAQs. Aria becomes your brand's voice.</p></div>
    <div class="feat"><div class="feat-icon" style="background:rgba(6,182,212,.12)">🌐</div><h3>Website call widget</h3><p>Embed a floating "Call Us" button on any website. Customers see your number and call with one tap.</p></div>
  </div>
</section>

<!-- INDUSTRIES -->
<section id="industries">
  <div class="section-label">Who it's for</div>
  <h2>Built for every local business</h2>
  <p class="section-sub">If your business gets phone calls, RingDesk pays for itself.</p>
  <div class="industries-grid">
    <div class="industry"><div class="industry-icon">🦷</div><div><div class="industry-name">Dental Clinics</div><div class="industry-desc">Appointments & insurance</div></div></div>
    <div class="industry"><div class="industry-icon">🏠</div><div><div class="industry-name">Estate Agents</div><div class="industry-desc">Property enquiries & viewings</div></div></div>
    <div class="industry"><div class="industry-icon">🔧</div><div><div class="industry-name">Tradespeople</div><div class="industry-desc">Quote requests & bookings</div></div></div>
